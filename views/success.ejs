<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">

    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>QR Generated</title>

    <link rel="stylesheet" href="/css/style.css">

</head>

<body>

<header class="main-header">
    <a href="/">
        <img src="/images/logo.png" class="logo" alt="QR-Found Logo">
    </a>
</header>

<div class="container">

    <div class="success-title">

        Thank you,
        <%= item.owner_name %>!

    </div>

    <div class="success-title">

        Your QR-Found code is ready.

    </div>

    <div class="sub-title">

        Your Unique QR Code

    </div>

    <div class="qr-container">

        <img
            src="<%= qrCode %>"
            class="qr-img"
        >

    </div>

    <!-- PDF BUTTON -->
    <a
        href="/generate_pdf/<%= item._id %>"
        class="btn"
    >

        Download PDF

    </a>

    <!-- PNG BUTTON -->
    <a
        href="/generate_png/<%= item._id %>"
        class="btn btn-secondary"
    >

        Download PNG

    </a>

    <ul class="instruction-list">

        <li>
            1. Print the downloaded PDF.
        </li>

        <li>
            2. Attach the tag securely to your item.
        </li>

    </ul>

    <div class="warning">

        This is a temporary page.
        Download your QR code before leaving.

    </div>

    <div class="success-small">

        Protect another item
        in just one minute.

    </div>

    <button class="btn" onclick="openModal()">
    Create new QR-code
</button>

</div>


<footer class="main-footer">
    <div>
        © 2026 QR-Found
    </div>
    <div style="margin-top: 10px;">
        <a href="/faq" class="footer-link">FAQ</a>
    </div>
</footer>

<div class="overlay" id="overlay">

    <div class="modal">

        <div class="close-btn" onclick="closeModal()">×</div>

        <div class="gradient-title">
            Create your QR code
        </div>

        <div style="font-size:14px; color:#666; line-height:1.4; margin-bottom:15px;">
            Fill in a few simple details so your item can be returned to you if it gets lost.  
            This information helps the finder contact you quickly and safely.
        </div>

        <form action="/create" method="POST">

            <input type="text" name="item_name" placeholder="Item name" required>
            <input type="text" name="owner_name" placeholder="Owner name" required>

            <div class="phone-row">

                <select name="country_code" class="phone-code">

    <option value="+1">🇺🇸 +1</option>
    <option value="+1">🇨🇦 +1</option>

    <option value="+44">🇬🇧 +44</option>

    <option value="+49">🇩🇪 +49</option>
    <option value="+33">🇫🇷 +33</option>
    <option value="+39">🇮🇹 +39</option>
    <option value="+34">🇪🇸 +34</option>

    <option value="+48">🇵🇱 +48</option>
    <option value="+380" selected>🇺🇦 +380</option>

    <option value="+420">🇨🇿 +420</option>
    <option value="+40">🇷🇴 +40</option>
    <option value="+36">🇭🇺 +36</option>

    <option value="+90">🇹🇷 +90</option>

    <option value="+971">🇦🇪 +971</option>

    <option value="+81">🇯🇵 +81</option>
    <option value="+82">🇰🇷 +82</option>
    <option value="+86">🇨🇳 +86</option>

    <option value="+91">🇮🇳 +91</option>

    <option value="+61">🇦🇺 +61</option>

</select>

                <input type="text" name="phone" class="phone-input" placeholder="Phone" required>

            </div>

            <input type="email" name="email" placeholder="Email" required>
            <input type="text" name="telegram" placeholder="@telegram" required>

            <button class="btn">Generate QR</button>

        </form>

    </div>

</div>
</body>

</html>
<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">

    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Found Item</title>

    <link rel="stylesheet" href="/css/style.css">

</head>

<body>

<header class="main-header">
    <a href="/">
        <img src="/images/logo.png" class="logo" alt="QR-Found Logo">
    </a>
</header>

<div class="container">

    <div class="found-title">

        Found an Item?

    </div>

    <div class="hero-text">

        Thank you for being a hero!
        Here is the owner's contact information.

    </div>

    <div class="info-card">

        <div class="info-row">

            <div class="info-label">
                Item:
            </div>

            <div class="info-value">
                <%= item.item_name %>
            </div>

        </div>

        <div class="info-row">

            <div class="info-label">
                Owner:
            </div>

            <div class="info-value">
                <%= item.owner_name %>
            </div>

        </div>

        <div class="info-row">

            <div class="info-label">
                Email:
            </div>

            <div class="info-value">
                <%= item.email %>
            </div>

        </div>

    </div>

    <a
        href="tel:<%= item.phone %>"
        class="btn"
    >

        Call owner

    </a>

    <a
        href="https://t.me/<%= item.telegram.replace('@','') %>"
        class="btn"
    >

        Chat on telegram

    </a>

    <div class="footer-note">

        Your kindness makes the world a better place!

    </div>

    <div class="protect-box">

        <div class="protect-title">

            Protect your items too!

        </div>

        <div class="protect-text">

            Create your own smart QR tag
            in just one minute.

        </div>

        <a href="/" class="btn">

            Create QR-code

        </a>

    </div>

</div>

<footer class="main-footer">
    <div>
        © 2026 QR-Found
    </div>
    <div style="margin-top: 10px;">
        <a href="/faq" class="footer-link">FAQ</a>
    </div>
</footer>


</body>

</html>
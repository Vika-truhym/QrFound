<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">

    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Found Item</title>

    <link rel="stylesheet" href="/css/style.css">

</head>

<body>

<header class="main-header">
    <a href="/">
        <img src="/images/logo.png" class="logo" alt="QR-Found Logo">
    </a>
</header>

<div class="container">

    <div class="found-title">

        Found an Item?

    </div>

    <div class="hero-text">

        Thank you for being a hero!
        Here is the owner's contact information.

    </div>

    <div class="info-card">

        <div class="info-row">

            <div class="info-label">
                Item:
            </div>

            <div class="info-value">
                <%= item.item_name %>
            </div>

        </div>

        <div class="info-row">

            <div class="info-label">
                Owner:
            </div>

            <div class="info-value">
                <%= item.owner_name %>
            </div>

        </div>

        <div class="info-row">

            <div class="info-label">
                Email:
            </div>

            <div class="info-value">
                <%= item.email %>
            </div>

        </div>

    </div>

    <a
        href="tel:<%= item.phone %>"
        class="btn"
    >

        Call owner

    </a>

    <a
        href="https://t.me/<%= item.telegram.replace('@','') %>"
        class="btn"
    >

        Chat on telegram

    </a>

    <div class="footer-note">

        Your kindness makes the world a better place!

    </div>

    <div class="protect-box">

        <div class="protect-title">

            Protect your items too!

        </div>

        <div class="protect-text">

            Create your own smart QR tag
            in just one minute.

        </div>

        <button class="btn" onclick="openModal()">
    Create QR-code
</button>

        </div>
<div class="overlay" id="scannerOverlay">
    <div class="modal">
        <div class="close-btn" onclick="closeScanner()">×</div>
        <div class="gradient-title">Scan QR Code</div>
        
        <div id="reader" style="width: 100%; max-width: 400px; margin: 0 auto;"></div>
        
        <div class="description" style="margin-top: 15px;">
            Align the QR code within the frame to scan.
        </div>
    </div>
</div>

    <div class="overlay" id="overlay">

        <div class="modal">

            <div class="close-btn" onclick="closeModal()">

                ×

            </div>

            <div class="gradient-title">

                Create your QR code

            </div>
             <div style="font-size:14px; color:#666; line-height:1.4; margin-bottom:15px;">
        Fill in a few simple details so your item can be returned to you if it gets lost.  
        This information helps the finder contact you quickly and safely.
    </div>

            <form action="/create" method="POST">

                <input
                    type="text"
                    name="item_name"
                    placeholder="Item name"
                    required
                >

                <input
                    type="text"
                    name="owner_name"
                    placeholder="Owner name"
                    required
                >

                <div class="phone-row">

                   <select name="country_code" class="phone-code">

    <option value="+1">🇺🇸 +1</option>
    <option value="+1">🇨🇦 +1</option>

    <option value="+44">🇬🇧 +44</option>

    <option value="+49">🇩🇪 +49</option>
    <option value="+33">🇫🇷 +33</option>
    <option value="+39">🇮🇹 +39</option>
    <option value="+34">🇪🇸 +34</option>

    <option value="+48">🇵🇱 +48</option>
    <option value="+380" selected>🇺🇦 +380</option>

    <option value="+420">🇨🇿 +420</option>
    <option value="+40">🇷🇴 +40</option>
    <option value="+36">🇭🇺 +36</option>

    <option value="+90">🇹🇷 +90</option>

    <option value="+971">🇦🇪 +971</option>

    <option value="+81">🇯🇵 +81</option>
    <option value="+82">🇰🇷 +82</option>
    <option value="+86">🇨🇳 +86</option>

    <option value="+91">🇮🇳 +91</option>

    <option value="+61">🇦🇺 +61</option>

</select>

                    <input
                        type="text"
                        name="phone"
                        class="phone-input"
                        placeholder="Phone"
                        required
                    >

                </div>

                <input
                    type="email"
                    name="email"
                    placeholder="Email"
                    required
                >

                <input
                    type="text"
                    name="telegram"
                    placeholder="@telegram"
                    required
                >

                <button class="btn">

                    Generate QR

                </button>

            </form>

        </div>

    </div>
    </div>

</div>

<footer class="main-footer">
    <div>
        © 2026 QR-Found
    </div>
    <div style="margin-top: 10px;">
        <a href="/faq" class="footer-link">FAQ</a>
    </div>
</footer>

<script src="/js/main.js"></script>
</body>

</html>